# Database
# Format: postgresql://user:pass@host:5432/dbname
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trackshell

# Auth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# Redis
REDIS_URL=redis://localhost:6379

# Maps — must be NEXT_PUBLIC_ to expose to browser
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here

# Internal pipeline API
PIPELINE_API_URL=https://pipeline.internal.golfmap.io
PIPELINE_API_KEY=your_pipeline_api_key_here

# AWS
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
